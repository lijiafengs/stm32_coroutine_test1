{
  "configurations": [
    {
      "name": "STM32F407ZE",
      "compilerPath": "${config:stm32.gccPath}\\arm-none-eabi-g++.exe",
      "cStandard": "c11",
      "cppStandard": "c++20",
      "intelliSenseMode": "gcc-arm",
      "defines": [
        "STM32F407xx",
        "USE_HAL_DRIVER",
        "HSE_VALUE=8000000"
      ],
      "includePath": [
        "${workspaceFolder}\\include",
        "${workspaceFolder}\\Drivers\\STM32F4xx\\CMSIS\\Core\\Include",
        "${workspaceFolder}\\Drivers\\STM32F4xx\\CMSIS\\Include",
        "${workspaceFolder}\\Drivers\\STM32F4xx\\CMSIS\\Device\\ST\\STM32F4xx\\Include",
        "${workspaceFolder}\\Drivers\\STM32F4xx\\STM32F4xx_HAL_Driver\\Inc"
      ]
    }
  ],
  "version": 4
}
